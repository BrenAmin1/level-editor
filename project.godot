[application]

config/name="Rain Level Editor"
config/description="Level Editor for Rain"
config/version="0.5"
run/main_scene="uid://biburdoup3tys"
config/use_custom_user_dir=true
config/custom_user_dir_name="Rain Level Editor"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=600
boot_splash/show_image=false
config/icon="uid://b5qfdg6swfrvv"
config/windows_native_icon="res://Icons/tile_cube.ico"

[autoload]

AppConfig="*uid://dxl5x1sobnvvc"
Console="*uid://55d7lhfm2dn2"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/vsync/vsync_mode=0

